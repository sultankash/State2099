<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>State 2099 WAR ROOM</title>
<style>
:root{
  --bg:#07111f;--bg2:#0b182a;--card:#10243b;--card2:#0d1c30;--line:#28415f;--line2:#395a80;
  --text:#f1f7ff;--muted:#aec0d6;--ice:#7dd3fc;--green:#6ee7b7;--gold:#fde68a;--red:#fca5a5;--purple:#c4b5fd;
  --amt:#0e3a5e;--pro:#2c3b17;--flex:#43330e;--shadow:0 22px 70px rgba(0,0,0,.38);--r:22px;
}
*{box-sizing:border-box}html{background:var(--bg)}body{margin:0;min-height:100vh;color:var(--text);font-family:Inter,Segoe UI,Tahoma,Arial,sans-serif;background:
radial-gradient(circle at 15% 0%,rgba(125,211,252,.22),transparent 28%),
radial-gradient(circle at 85% 0%,rgba(196,181,253,.18),transparent 28%),
linear-gradient(180deg,#07182b,#050b14 62%,#03060c)}
button,input,select,textarea{font:inherit}button{cursor:pointer}
.wrap{max-width:1220px;margin:0 auto;padding:18px 12px 42px}.top{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:16px}
.brand{display:flex;gap:13px;align-items:center}.logo{width:52px;height:52px;border-radius:18px;background:linear-gradient(135deg,#7dd3fc,#6ee7b7);display:grid;place-items:center;color:#04101c;font-weight:1000;box-shadow:0 14px 38px rgba(34,197,94,.18)}
h1{margin:0;font-size:28px;letter-spacing:.02em}.sub{color:var(--muted);font-size:13px;margin-top:4px}.pill{border:1px solid var(--line);background:rgba(16,36,59,.76);border-radius:999px;padding:9px 12px;color:#d8e6f7;font-weight:800;font-size:12px;white-space:nowrap}
.tabs{display:flex;gap:9px;overflow-x:auto;padding-bottom:8px;margin-bottom:10px}.tab{border:1px solid var(--line);background:#0c1c31;color:#d8e6f7;border-radius:999px;padding:11px 15px;font-weight:950;white-space:nowrap}.tab.active{background:linear-gradient(135deg,#2563eb,#38bdf8);border-color:transparent;color:#fff}
.grid{display:grid;gap:14px}.layout{display:grid;grid-template-columns:1.05fr .95fr;gap:14px}.card{background:linear-gradient(180deg,rgba(18,40,66,.98),rgba(10,22,37,.98));border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden}.head{display:flex;justify-content:space-between;align-items:center;gap:10px;padding:15px 17px;border-bottom:1px solid var(--line)}.head h2{margin:0;font-size:17px}.body{padding:15px}
.formGrid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:11px}.span2{grid-column:span 2}.span4{grid-column:span 4}
label{display:block;color:#b7c8dc;font-size:11px;letter-spacing:.04em;font-weight:950;text-transform:uppercase;margin-bottom:6px}input,select,textarea{width:100%;border:1px solid var(--line);background:#071528;color:#eef7ff;border-radius:14px;padding:12px 12px;outline:0;font-size:14px}input:focus,select:focus,textarea:focus{border-color:var(--ice);box-shadow:0 0 0 3px rgba(125,211,252,.12)}textarea{min-height:82px;line-height:1.43;resize:vertical}select option{background:#071528;color:#eef7ff}
.section{grid-column:1/-1;margin:7px 0 0;border:1px solid var(--line);border-radius:16px;padding:12px;background:#08182b}.sectionTitle{font-weight:1000;letter-spacing:.06em;text-transform:uppercase;color:#e8f7ff;margin-bottom:10px}.section.amt{border-color:rgba(125,211,252,.35);background:linear-gradient(180deg,rgba(14,58,94,.55),rgba(8,24,43,.92))}.section.pro{border-color:rgba(110,231,183,.32);background:linear-gradient(180deg,rgba(44,59,23,.54),rgba(8,24,43,.92))}.section.flex{border-color:rgba(253,230,138,.35);background:linear-gradient(180deg,rgba(67,51,14,.55),rgba(8,24,43,.92))}
.inline3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.heroGrid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}.joinerGrid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.otherName{display:none;margin-top:6px}.show{display:block!important}.hide{display:none!important}
.btns{display:flex;gap:9px;flex-wrap:wrap;margin-top:13px}.btn{border:1px solid var(--line);background:#132b47;color:#f2f8ff;border-radius:14px;padding:10px 13px;font-weight:950;display:inline-flex;gap:8px;align-items:center;justify-content:center}.btn:hover{border-color:#6e91bd;transform:translateY(-1px)}.btn.primary{background:linear-gradient(135deg,#2563eb,#38bdf8);border:0}.btn.green{background:linear-gradient(135deg,#059669,#34d399);border:0;color:#03140c}.btn.gold{background:linear-gradient(135deg,#b45309,#fde68a);border:0;color:#170d03}.btn.red{background:#431520;color:#fecaca;border-color:#7f1d1d}.btn.ghost{background:transparent}.btn.small{font-size:12px;padding:7px 9px;border-radius:10px}
.preview{white-space:pre-wrap;background:#061224;border:1px dashed #476789;border-radius:16px;padding:13px;line-height:1.44;min-height:110px;color:#e7f0ff}.preview.rtl{direction:rtl;text-align:right;font-family:Tahoma,Arial,sans-serif}.mini{font-size:12px;color:var(--muted);margin-top:6px}.ok{color:#86efac}.bad{color:#fecaca}.warn{color:#fde68a}
.lock{position:fixed;inset:0;z-index:50;display:grid;place-items:center;background:radial-gradient(circle at top,#10365c,#040912 58%)}.lockBox{width:min(430px,92vw);background:rgba(16,36,59,.97);border:1px solid var(--line);border-radius:28px;box-shadow:var(--shadow);padding:23px}.lockBox h2{margin:14px 0 5px;font-size:26px}
.toast{position:fixed;right:14px;bottom:14px;z-index:60;display:none;max-width:min(410px,92vw);background:#0f172a;border:1px solid var(--line2);border-radius:16px;color:#fff;padding:12px 14px;box-shadow:var(--shadow)}.toast.show{display:block}
.tableWrap{overflow:auto;border:1px solid var(--line);border-radius:17px;background:#071528}table{width:100%;border-collapse:collapse;min-width:1040px}th,td{padding:10px 11px;border-bottom:1px solid var(--line);text-align:left;vertical-align:top;font-size:12.5px}th{background:#13213a;color:#dbeafe;text-transform:uppercase;letter-spacing:.04em;position:sticky;top:0}td{color:#e7effb}.tag{display:inline-flex;border-radius:999px;padding:4px 8px;font-weight:1000;font-size:11px}.tag.amt{background:#16496e;color:#bae6fd}.tag.pro{background:#304912;color:#d9f99d}.tag.flex{background:#583f10;color:#fde68a}.nowrap{white-space:nowrap}
.msgTabs{display:flex;gap:7px;margin-bottom:10px}.msgTab{flex:1;border:1px solid var(--line);border-radius:12px;padding:9px;background:#071528;color:#d8e6f7;font-weight:950}.msgTab.active{background:#1d4ed8;color:#fff;border-color:#7dd3fc}.split{display:grid;grid-template-columns:1fr 1fr;gap:10px}
@media(max-width:920px){.layout{grid-template-columns:1fr}.formGrid{grid-template-columns:1fr 1fr}.span4{grid-column:span 2}.heroGrid,.joinerGrid{grid-template-columns:1fr 1fr}.top{align-items:flex-start;flex-direction:column}}
@media(max-width:560px){.wrap{padding:13px 9px 34px}h1{font-size:23px}.formGrid,.heroGrid,.joinerGrid,.inline3,.split{grid-template-columns:1fr}.span2,.span4{grid-column:span 1}.body{padding:12px}.head{padding:13px}.btn{width:100%}.btn.small{width:auto}.pill{white-space:normal}}
</style>
</head>
<body>
<div class="lock" id="lock"><div class="lockBox"><div class="logo">2099</div><h2>WAR ROOM</h2><div class="sub">Planning access required</div><input id="password" type="password" placeholder="Password" onkeydown="if(event.key==='Enter')unlock()"><div class="btns"><button class="btn primary" onclick="unlock()">Enter</button></div></div></div>
<div class="wrap">
 <div class="top"><div class="brand"><div class="logo">2099</div><div><h1>State 2099 WAR ROOM</h1><div class="sub">Rally leaders · Joiners · Flex · Arabic/English game-safe messages</div></div></div><div class="pill" id="apiStatus">Connecting...</div></div>
 <div class="tabs"><button class="tab active" data-tab="rally" onclick="setTab('rally')">Rally Leader</button><button class="tab" data-tab="joiner" onclick="setTab('joiner')">Joiner</button><button class="tab" data-tab="saved" onclick="setTab('saved')">Saved Plans</button><button class="tab" data-tab="downloads" onclick="setTab('downloads')">Downloads</button></div>
 <section id="tab-rally" class="tabPage">
  <div class="layout">
   <div class="card"><div class="head"><h2>Create Rally Plan</h2><span class="mini">Save & Add Next</span></div><div class="body">
    <div class="formGrid">
     <div><label>Language</label><select id="rLang" onchange="refreshRallyPreview()"><option>Arabic</option><option>English</option></select></div>
     <div><label>Plan Type</label><select id="planType" onchange="onPlanTypeChange()"><option>AMT</option><option>PRO</option><option>Flex</option></select></div>
     <div><label>Rally Leader</label><select id="leader" onchange="toggleLeaderOther();refreshRallyPreview()"></select></div>
     <div id="leaderOtherWrap"><label>Other Leader Name</label><input id="otherLeader" placeholder="Leader name" oninput="refreshRallyPreview()"></div>
     <div id="flexScenarioWrap" class="span4 hide"><label>Flex Scenario</label><select id="flexScenario" onchange="refreshRallyPreview()"><option>Pets First ثم انتقال</option><option>Before Castle / قبل وقت القلعة</option><option>After Castle / بعد القلعة</option></select><div class="mini">Arabic Flex will be copied as two clean messages.</div></div>
     <div class="span4"><label>Organizer Notes</label><textarea id="rNotes" placeholder="Optional, appears in simple brief" oninput="refreshRallyPreview()"></textarea></div>
    </div>
    <div id="assignment1"></div>
    <div id="assignment2" class="hide"></div>
    <div class="btns"><button class="btn primary" onclick="refreshRallyPreview(true)">Generate Preview</button><button class="btn green" onclick="saveRally()">Save & Add Next</button><button class="btn ghost" onclick="clearRallyForm()">Clear Form</button></div>
   </div></div>
   <div class="card"><div class="head"><h2>Rally Message Preview</h2><span class="mini" id="rCounter">Ready</span></div><div class="body">
    <div class="msgTabs"><button id="rTabAR" class="msgTab active" onclick="showRallyMsg('ar')">Arabic</button><button id="rTabEN" class="msgTab" onclick="showRallyMsg('en')">English</button></div>
    <div id="rPreviewAR" class="preview rtl"></div><div id="rPreviewEN" class="preview hide"></div>
    <div id="flexCopyBtns" class="btns hide"><button class="btn" onclick="copyText(window.rallyMessages?.[0]?.messageAR||'')">Copy AR Message 1</button><button class="btn" onclick="copyText(window.rallyMessages?.[1]?.messageAR||'')">Copy AR Message 2</button></div>
    <div class="btns"><button class="btn" onclick="copyCurrentRally()">Copy Current</button><button class="btn gold" onclick="copyAllRally()">Copy All</button></div>
   </div></div>
  </div>
 </section>
 <section id="tab-joiner" class="tabPage hide">
  <div class="layout">
   <div class="card"><div class="head"><h2>Create Joiner Message</h2><span class="mini">Rows + Other Heroes</span></div><div class="body">
    <div class="formGrid">
     <div><label>Language</label><select id="jLang" onchange="onJoinerLangChange()"><option>Arabic</option><option>English</option></select></div>
     <div><label>Alliance</label><select id="jAlliance" onchange="refreshJoinerPreview()"><option>AMT</option><option>PRO</option></select></div>
     <div><label>Castle Row / Rules</label><select id="jRow" onchange="refreshJoinerPreview()"></select></div>
     <div><label>Notes</label><input id="jNotes" placeholder="Optional" oninput="refreshJoinerPreview()"></div>
     <div class="span4 section"><div class="sectionTitle">Joiner Heroes</div><div id="joinerHeroes" class="joinerGrid"></div></div>
     <div class="span4 section"><div class="sectionTitle">Formation</div><div class="inline3"><div><label>INF</label><input id="jInf" type="number" value="60" oninput="refreshJoinerPreview()"></div><div><label>LAN</label><input id="jLan" type="number" value="40" oninput="refreshJoinerPreview()"></div><div><label>MM</label><input id="jMm" type="number" value="0" oninput="refreshJoinerPreview()"></div></div><div id="jTotal" class="mini"></div></div>
    </div>
    <div class="btns"><button class="btn primary" onclick="refreshJoinerPreview(true)">Generate Preview</button><button class="btn green" onclick="saveJoiner()">Save Joiner Group</button><button class="btn ghost" onclick="clearJoinerForm()">Clear</button></div>
   </div></div>
   <div class="card"><div class="head"><h2>Joiner Message Preview</h2><span class="mini" id="jCounter">Ready</span></div><div class="body"><div class="msgTabs"><button id="jTabAR" class="msgTab active" onclick="showJoinerMsg('ar')">Arabic</button><button id="jTabEN" class="msgTab" onclick="showJoinerMsg('en')">English</button></div><div id="jPreviewAR" class="preview rtl"></div><div id="jPreviewEN" class="preview hide"></div><div class="btns"><button class="btn" onclick="copyCurrentJoiner()">Copy Current</button></div></div></div>
  </div>
 </section>
 <section id="tab-saved" class="tabPage hide"><div class="card"><div class="head"><h2>Saved Rally Plans</h2><button class="btn small" onclick="loadSaved()">Refresh</button></div><div class="body"><div class="tableWrap"><table><thead><tr><th>#</th><th>Type</th><th>Leader</th><th>Alliance</th><th>Team</th><th>Pets</th><th>Rally Heroes</th><th>Formation</th><th>Joiners</th><th>Actions</th></tr></thead><tbody id="plansBody"><tr><td colspan="10">No data yet.</td></tr></tbody></table></div></div></div><div class="card" style="margin-top:14px"><div class="head"><h2>Saved Joiner Groups</h2></div><div class="body"><div class="tableWrap"><table><thead><tr><th>#</th><th>Alliance</th><th>Row</th><th>Heroes</th><th>Formation</th><th>Actions</th></tr></thead><tbody id="groupsBody"><tr><td colspan="6">No data yet.</td></tr></tbody></table></div></div></div></section>
 <section id="tab-downloads" class="tabPage hide"><div class="layout"><div class="card"><div class="head"><h2>Download Files</h2><span class="mini">Same data, two outputs</span></div><div class="body"><p class="sub">Full Plan is for organizers. Simple Brief is the vertical screenshot-friendly share file.</p><div class="btns"><button class="btn primary" onclick="downloadExcel('downloadFullPlan')">Download Full Plan</button><button class="btn green" onclick="downloadExcel('downloadSimpleBrief')">Download Simple Brief</button></div></div></div><div class="card"><div class="head"><h2>Danger Zone</h2></div><div class="body"><p class="sub">Clear only WAR ROOM planning rows. It does not touch the old website.</p><button class="btn red" onclick="clearPlanningData()">Clear Planning Data</button></div></div></div></section>
</div>
<div class="toast" id="toast"></div>
<script>
const API = 'https://script.google.com/macros/s/AKfycbwkfYBCVLUO13arz7E-VEMi1QV53m1Gtkz5qccLvyGADS-NcTyF4kOzIi6g3yuZ8ZEz8A/exec';
const PASSWORD = 'StateOf2099';
const FALLBACK = {
  rallyLeaders:['Zero','KSA Abu Sanad','FAS','Final Option','Kaki','Kanis','Maher','Anas','Fahad','Tusi','Bu3ajeel','Monster','NightKing','777','Maximus','Sultan','Other'],
  heroes:['Sergey','Jessie','Patrick','Lumak Bokan','Ling Xue','Gina','Bahiti','Jasser','Seo-yoon','Natalia','Jeronimo','Molly','Zinman','Flint','Philly','Alonso','Logan','Mia','Greg','Ahmose','Reina','Lynn','Hector','Norah','Gwen','Wu Ming','Renee','Wayne','Edith','Gordon','Bradley','Gatot','Sonya','Hendrik','Magnus','Fred','Xura','Gregory','Freya','Blanchette','Eleonora','Lloyd','Rufus','Hervor','Karol','Ligeia','Gisela','Flora','Vulcanus','Elif','Dominic','Cara','Hank','Estrella','Viveca','Seigel','Ursar','Aisling','Other'],
  amtTeams:Array.from({length:10},(_,i)=>`TEAM AMT${i+1}`), proTeams:Array.from({length:10},(_,i)=>`TEAM PRO${i+1}`),
  pets:['No Pets',...Array.from({length:48},(_,i)=>`${String(Math.floor(i/2)).padStart(2,'0')}:${i%2?'30':'00'} UTC`)],
  rowRulesAR:['صف ثاني','صف ثالث','بدون قوانين'], rowRulesEN:['Row 2','Row 3','No rules']
};
let config=FALLBACK, activeRallyLang='ar', activeJoinerLang='ar'; window.rallyMessages=[]; window.joinerMessage={messageAR:'',messageEN:''};
const $=id=>document.getElementById(id);
function unlock(){ if($('password').value.trim()!==PASSWORD) return toast('Wrong password'); sessionStorage.setItem('warroom_ok','1'); $('lock').classList.add('hide'); init(); }
window.addEventListener('load',()=>{ buildStatic(); if(sessionStorage.getItem('warroom_ok')==='1'){ $('lock').classList.add('hide'); init(); } });
async function init(){ await getConfig(); toggleLeaderOther(); renderAssignments(); onPlanTypeChange(); onJoinerLangChange(); refreshRallyPreview(); refreshJoinerPreview(); loadSaved(); }
function buildStatic(){ fillSelect('leader',FALLBACK.rallyLeaders); }
async function getConfig(){ try{ const j=await fetch(API+'?action=getConfig&ts='+Date.now()).then(r=>r.json()); if(j.ok) config={...FALLBACK,...j}; $('apiStatus').innerHTML=`Connected · ${j.version||'API'}`; }catch(e){ $('apiStatus').innerHTML='<span class="warn">Offline fallback lists</span>'; } fillSelect('leader',config.rallyLeaders||FALLBACK.rallyLeaders); }
function setTab(t){ document.querySelectorAll('.tab').forEach(b=>b.classList.toggle('active',b.dataset.tab===t)); document.querySelectorAll('.tabPage').forEach(p=>p.classList.add('hide')); $('tab-'+t).classList.remove('hide'); if(t==='saved') loadSaved(); }
function fillSelect(id,arr,val){ const el=$(id); if(!el)return; el.innerHTML=(arr||[]).map(x=>`<option value="${esc(x)}">${esc(x)}</option>`).join(''); if(val) el.value=val; }
function teamOptions(alliance){ return alliance==='AMT' ? (config.amtTeams||FALLBACK.amtTeams) : (config.proTeams||FALLBACK.proTeams); }
function petOptions(){ return config.pets || FALLBACK.pets; }
function heroes(){ return config.heroes || FALLBACK.heroes; }
function toggleLeaderOther(){ $('leaderOtherWrap').classList.toggle('hide',$('leader').value!=='Other'); }
function onPlanTypeChange(){ const t=$('planType').value; $('flexScenarioWrap').classList.toggle('hide',t!=='Flex'); $('assignment2').classList.toggle('hide',t!=='Flex'); const a1=assignmentEls(1), a2=assignmentEls(2); if(t==='AMT'){ a1.alliance.value='AMT'; a1.alliance.disabled=true; } else if(t==='PRO'){ a1.alliance.value='PRO'; a1.alliance.disabled=true; } else { a1.alliance.disabled=false; a2.alliance.disabled=false; } updateTeamSelect(1); updateTeamSelect(2); refreshRallyPreview(); }
function assignmentEls(n){ return {alliance:$(`a${n}Alliance`),team:$(`a${n}Team`),pet:$(`a${n}Pet`),rHeroes:[1,2,3].map(i=>$(`a${n}RHero${i}`)),rOther:[1,2,3].map(i=>$(`a${n}RHeroOther${i}`)),rInf:$(`a${n}RInf`),rLan:$(`a${n}RLan`),rMm:$(`a${n}RMm`),jHeroes:[1,2,3,4].map(i=>$(`a${n}JHero${i}`)),jOther:[1,2,3,4].map(i=>$(`a${n}JHeroOther${i}`)),jInf:$(`a${n}JInf`),jLan:$(`a${n}JLan`),jMm:$(`a${n}JMm`)}; }
function renderAssignments(){ $('assignment1').innerHTML=assignmentHtml(1,'Assignment 1'); $('assignment2').innerHTML=assignmentHtml(2,'Assignment 2'); [1,2].forEach(n=>{ fillSelect(`a${n}Alliance`,['AMT','PRO'],n===1?'AMT':'PRO'); updateTeamSelect(n); fillSelect(`a${n}Pet`,petOptions(),n===1?'12:00 UTC':'No Pets'); [1,2,3].forEach(i=>fillSelect(`a${n}RHero${i}`,heroes(),['Gatot','Sonya','Bradley'][i-1])); [1,2,3,4].forEach(i=>fillSelect(`a${n}JHero${i}`,heroes(),['Jessie','Jasser','Norah','Hector'][i-1])); }); renderJoinerHeroes(); }
function assignmentHtml(n,title){ const type=n===1?'amt':'pro'; return `<div class="section ${type}"><div class="sectionTitle">${title}</div><div class="formGrid"><div><label>Alliance</label><select id="a${n}Alliance" onchange="updateTeamSelect(${n});refreshRallyPreview()"></select></div><div><label>Team</label><select id="a${n}Team" onchange="refreshRallyPreview()"></select></div><div><label>Pet Activation</label><select id="a${n}Pet" onchange="refreshRallyPreview()"></select></div><div><label>Rally Formation Total</label><div class="mini" id="a${n}RTotal">—</div></div><div class="span4"><label>Rally Heroes</label><div class="heroGrid">${[1,2,3].map(i=>heroSelectHtml(`a${n}RHero${i}`,`a${n}RHeroOther${i}`)).join('')}</div></div><div class="span4"><label>Rally Formation</label><div class="inline3"><input id="a${n}RInf" type="number" value="60" oninput="refreshRallyPreview()"><input id="a${n}RLan" type="number" value="40" oninput="refreshRallyPreview()"><input id="a${n}RMm" type="number" value="0" oninput="refreshRallyPreview()"></div></div><div class="span4"><label>Joiner Heroes For This Rally</label><div class="joinerGrid">${[1,2,3,4].map(i=>heroSelectHtml(`a${n}JHero${i}`,`a${n}JHeroOther${i}`)).join('')}</div></div><div class="span4"><label>Joiner Formation</label><div class="inline3"><input id="a${n}JInf" type="number" value="60" oninput="refreshRallyPreview()"><input id="a${n}JLan" type="number" value="40" oninput="refreshRallyPreview()"><input id="a${n}JMm" type="number" value="0" oninput="refreshRallyPreview()"></div><div class="mini" id="a${n}JTotal">—</div></div></div></div>`; }
function heroSelectHtml(id,otherId){ return `<div><select id="${id}" onchange="toggleOtherHero('${id}','${otherId}');refreshRallyPreview()"></select><input class="otherName" id="${otherId}" placeholder="Other name" oninput="refreshRallyPreview()"></div>`; }
function updateTeamSelect(n){ const a=$(`a${n}Alliance`).value; fillSelect(`a${n}Team`,teamOptions(a)); }
function toggleOtherHero(selId,otherId){ $(otherId).classList.toggle('show',$(selId).value==='Other'); }
function renderJoinerHeroes(){ $('joinerHeroes').innerHTML=[1,2,3,4].map(i=>`<div><select id="jHero${i}" onchange="toggleOtherHero('jHero${i}','jHeroOther${i}');refreshJoinerPreview()"></select><input class="otherName" id="jHeroOther${i}" placeholder="Other name" oninput="refreshJoinerPreview()"></div>`).join(''); [1,2,3,4].forEach(i=>fillSelect(`jHero${i}`,heroes(),['Jessie','Jasser','Norah','Hector'][i-1])); }
function onJoinerLangChange(){ const lang=$('jLang').value; fillSelect('jRow',lang==='Arabic'?(config.rowRulesAR||FALLBACK.rowRulesAR):(config.rowRulesEN||FALLBACK.rowRulesEN)); activeJoinerLang=lang==='Arabic'?'ar':'en'; showJoinerMsg(activeJoinerLang); refreshJoinerPreview(); }
function getAssignment(n){ const e=assignmentEls(n); return {alliance:e.alliance.value,team:e.team.value,petActivation:e.pet.value,rallyHeroes:e.rHeroes.map(x=>x.value),rallyOtherHeroes:e.rOther.map(x=>x.value),rallyFormation:{inf:num(e.rInf),lan:num(e.rLan),mm:num(e.rMm)},joinerHeroes:e.jHeroes.map(x=>x.value),joinerOtherHeroes:e.jOther.map(x=>x.value),joinerFormation:{inf:num(e.jInf),lan:num(e.jLan),mm:num(e.jMm)}}; }
function getRallyPlan(){ const planType=$('planType').value; const assignments=[getAssignment(1)]; if(planType==='Flex') assignments.push(getAssignment(2)); return {planType, language:$('rLang').value, leader:$('leader').value, otherLeader:$('otherLeader').value, flexScenario:$('flexScenario').value, notes:$('rNotes').value, assignments}; }
function getJoinerGroup(){ return {language:$('jLang').value, alliance:$('jAlliance').value, rowRule:$('jRow').value, heroes:[1,2,3,4].map(i=>$(`jHero${i}`).value), otherHeroes:[1,2,3,4].map(i=>$(`jHeroOther${i}`).value), formation:{inf:num($('jInf')),lan:num($('jLan')),mm:num($('jMm'))}, notes:$('jNotes').value}; }
function num(el){ return Number(el.value||0); }
function validateFormations(plan){ for(const [idx,a] of plan.assignments.entries()){ const rt=a.rallyFormation.inf+a.rallyFormation.lan+a.rallyFormation.mm; const jt=a.joinerFormation.inf+a.joinerFormation.lan+a.joinerFormation.mm; $(`a${idx+1}RTotal`).innerHTML=rt===100?'<span class="ok">100 OK</span>':`<span class="bad">${rt} / 100</span>`; $(`a${idx+1}JTotal`).innerHTML=jt===100?'<span class="ok">Joiners 100 OK</span>':`<span class="bad">Joiners ${jt} / 100</span>`; if(rt!==100||jt!==100) return false; } return true; }
async function refreshRallyPreview(force=false){ const plan=getRallyPlan(); const ok=validateFormations(plan); if(!ok){ $('rPreviewAR').textContent='مجموع النسب لازم يساوي 100'; $('rPreviewEN').textContent='Formation totals must equal 100'; return; } try{ const j=await apiPost('generateRallyMessage',{plan}); if(!j.ok) throw Error(j.error||'Preview failed'); window.rallyMessages=j.messages||[]; $('rPreviewAR').textContent=(j.messages||[]).map((m,i)=>plan.planType==='Flex'?`[${i+1}]\n${m.messageAR}`:m.messageAR).join('\n\n'); $('rPreviewEN').textContent=(j.messages||[]).map((m,i)=>plan.planType==='Flex'?`[${i+1}]\n${m.messageEN}`:m.messageEN).join('\n\n'); $('flexCopyBtns').classList.toggle('hide',plan.planType!=='Flex'); $('rCounter').textContent=`${($('rPreviewAR').textContent||'').length} chars AR`; }catch(e){ $('rPreviewAR').textContent='Preview error: '+e.message; $('rPreviewEN').textContent='Preview error: '+e.message; } }
async function refreshJoinerPreview(force=false){ const g=getJoinerGroup(); const total=g.formation.inf+g.formation.lan+g.formation.mm; $('jTotal').innerHTML=total===100?'<span class="ok">100 OK</span>':`<span class="bad">${total} / 100</span>`; if(total!==100){ $('jPreviewAR').textContent='مجموع النسبة لازم يساوي 100'; $('jPreviewEN').textContent='Formation total must equal 100'; return; } try{ const j=await apiPost('generateJoinerMessage',{group:g}); if(!j.ok) throw Error(j.error||'Preview failed'); window.joinerMessage=j; $('jPreviewAR').textContent=j.messageAR; $('jPreviewEN').textContent=j.messageEN; $('jCounter').textContent=`${j.messageAR.length} chars AR`; }catch(e){ $('jPreviewAR').textContent='Preview error: '+e.message; $('jPreviewEN').textContent='Preview error: '+e.message; } }
function showRallyMsg(lang){ activeRallyLang=lang; $('rTabAR').classList.toggle('active',lang==='ar'); $('rTabEN').classList.toggle('active',lang==='en'); $('rPreviewAR').classList.toggle('hide',lang!=='ar'); $('rPreviewEN').classList.toggle('hide',lang!=='en'); }
function showJoinerMsg(lang){ activeJoinerLang=lang; $('jTabAR').classList.toggle('active',lang==='ar'); $('jTabEN').classList.toggle('active',lang==='en'); $('jPreviewAR').classList.toggle('hide',lang!=='ar'); $('jPreviewEN').classList.toggle('hide',lang!=='en'); }
async function saveRally(){ try{ const plan=getRallyPlan(); if(!validateFormations(plan)) throw Error('Formation totals must equal 100'); const j=await apiPost('saveRallyPlan',{plan}); if(!j.ok) throw Error(j.error||'Save failed'); toast('Saved. Ready for next leader.'); clearRallyForm(true); loadSaved(); }catch(e){ toast('Save failed: '+e.message); } }
async function saveJoiner(){ try{ const g=getJoinerGroup(); const j=await apiPost('saveJoinerGroup',{group:g}); if(!j.ok) throw Error(j.error||'Save failed'); toast('Joiner group saved.'); loadSaved(); }catch(e){ toast('Save failed: '+e.message); } }
async function loadSaved(){ try{ const [p,g]=await Promise.all([fetch(API+'?action=getPlans&ts='+Date.now()).then(r=>r.json()),fetch(API+'?action=getJoinerGroups&ts='+Date.now()).then(r=>r.json())]); renderPlans(p.plans||[]); renderGroups(g.groups||[]); }catch(e){ toast('Load failed: '+e.message); } }
function renderPlans(plans){ const b=$('plansBody'); if(!plans.length){ b.innerHTML='<tr><td colspan="10">No data yet.</td></tr>'; return; } b.innerHTML=plans.map((p,i)=>`<tr><td>${i+1}</td><td><span class="tag ${(p['Plan Type']||'').toLowerCase()==='flex'?'flex':(p['Alliance']==='AMT'?'amt':'pro')}">${esc(p['Plan Type'])}</span></td><td>${esc(p['Display Leader'])}</td><td>${esc(p['Alliance'])}</td><td class="nowrap">${esc(p['Team'])}</td><td>${esc(p['Pet Activation'])}</td><td>${esc(p['Rally Heroes'])}</td><td>${esc(p['Rally Formation'])}</td><td>${esc(p['Joiner Heroes'])}</td><td><button class="btn small red" onclick="deleteRally('${escAttr(p['Plan ID'])}')">Delete</button></td></tr>`).join(''); }
function renderGroups(groups){ const b=$('groupsBody'); if(!groups.length){ b.innerHTML='<tr><td colspan="6">No data yet.</td></tr>'; return; } b.innerHTML=groups.map((g,i)=>`<tr><td>${i+1}</td><td>${esc(g['Alliance'])}</td><td>${esc(g['Castle Row / Rules'])}</td><td>${esc([g['Hero 1'],g['Hero 2'],g['Hero 3'],g['Hero 4']].filter(Boolean).join(' / '))}</td><td>${esc(g['Formation'])}</td><td><button class="btn small red" onclick="deleteJoiner('${escAttr(g['Group ID'])}')">Delete</button></td></tr>`).join(''); }
async function deleteRally(id){ if(!confirm('Delete this rally plan?'))return; const j=await apiPost('deleteRallyPlan',{planId:id}); if(j.ok){toast('Deleted');loadSaved();} else toast(j.error||'Delete failed'); }
async function deleteJoiner(id){ if(!confirm('Delete this joiner group?'))return; const j=await apiPost('deleteJoinerGroup',{groupId:id}); if(j.ok){toast('Deleted');loadSaved();} else toast(j.error||'Delete failed'); }
async function clearPlanningData(){ if(!confirm('Clear all WAR ROOM planning data?'))return; const j=await apiPost('clearPlanningData'); if(j.ok){toast('Planning data cleared');loadSaved();} else toast(j.error||'Clear failed'); }
async function downloadExcel(action){ try{ toast('Preparing Excel...'); const j=await apiPost(action,{}); if(!j.ok) throw Error(j.error||'Download failed'); const bin=atob(j.base64); const bytes=new Uint8Array(bin.length); for(let i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i); const blob=new Blob([bytes],{type:j.mimeType||'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=j.filename||'State2099_WAR_ROOM.xlsx'; document.body.appendChild(a); a.click(); a.remove(); setTimeout(()=>URL.revokeObjectURL(a.href),2500); toast('Download ready.'); }catch(e){ toast('Download failed: '+e.message); } }
function copyCurrentRally(){ copyText(activeRallyLang==='ar'?$('rPreviewAR').textContent:$('rPreviewEN').textContent); }
function copyAllRally(){ copyText($('rPreviewAR').textContent+'\n\n---\n\n'+$('rPreviewEN').textContent); }
function copyCurrentJoiner(){ copyText(activeJoinerLang==='ar'?$('jPreviewAR').textContent:$('jPreviewEN').textContent); }
async function copyText(t){ try{ await navigator.clipboard.writeText(t||''); toast('Copied.'); }catch(e){ toast('Copy failed. Select manually.'); } }
function clearRallyForm(keepMode=false){ if(!keepMode) $('planType').value='AMT'; $('leader').value='Zero'; $('otherLeader').value=''; $('rNotes').value=''; renderAssignments(); onPlanTypeChange(); refreshRallyPreview(); }
function clearJoinerForm(){ $('jAlliance').value='AMT'; $('jNotes').value=''; $('jInf').value=60;$('jLan').value=40;$('jMm').value=0; renderJoinerHeroes(); onJoinerLangChange(); refreshJoinerPreview(); }
async function apiPost(action,data){ const r=await fetch(API,{method:'POST',headers:{'Content-Type':'text/plain;charset=utf-8'},body:JSON.stringify({action,...data})}); const txt=await r.text(); try{ return JSON.parse(txt); }catch(e){ throw Error('Bad API response: '+txt.slice(0,160)); } }
function toast(msg){ const t=$('toast'); t.textContent=msg; t.classList.add('show'); clearTimeout(window.toastTimer); window.toastTimer=setTimeout(()=>t.classList.remove('show'),3300); }
function esc(s){ return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }
function escAttr(s){ return String(s??'').replace(/['\"\\]/g,''); }
</script>
</body>
